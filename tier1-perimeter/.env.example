# SURU Platform — Tier 1 Perimeter Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.
# Secrets must never be hardcoded — source from env vars or SOPS/age.

# ---- Router target ----
# IP or hostname of the pfSense / OPNsense router
ROUTER_HOST=192.168.1.1
ROUTER_SSH_USER=admin
# Path to SSH private key for router access (key-based auth required)
ROUTER_SSH_KEY=~/.ssh/suru_tier1_ed25519
# SSH host key checking behaviour (passed to -o StrictHostKeyChecking=).
# Accepted values: yes | accept-new | no
# Script default when unset: yes (strict — requires the key to be in known_hosts).
# For first-time provisioning where the router is not yet in known_hosts, set:
#   SSH_STRICT_HOST_KEY_CHECKING=accept-new
# (trusts new keys on first connect; rejects changed keys on subsequent connects)
# Revert to yes immediately after initial provisioning.
# SSH_STRICT_HOST_KEY_CHECKING=yes

# ---- Platform driver selection ----
# Which platform driver to use: pfsense | opnsense
# Can be overridden at runtime with --platform <name>
ROUTER_PLATFORM=pfsense

# ── Tier 4 frontdoor (single ingress on port 443) ──────────────────────────
# Hostname that syslog-ng presents as SNI when connecting to the frontdoor.
# The nginx stream block routes this SNI to logstash-pfsense:5140 (TCP passthrough).
# Add a pfSense DNS host override: syslog.suru.local → <frontdoor-LAN-IP>
FRONTDOOR_SYSLOG_SNI=syslog.suru.local
# Port for all Tier 1 → frontdoor connections (443 = literal port 443 requirement).
FRONTDOOR_PORT=443

# ---- Network interfaces ----
# Suricata interfaces — comma-separated list of pfSense LOGICAL interface names.
# Use the names shown in pfSense: Interfaces > Assignments (e.g. lan, opt1, wan).
# The deploy pipeline registers each interface in the pfSense Suricata XML model
# and applies the SURU rule-selection baseline to all of them.
# For standalone (non-pfSense) use: set physical interface names (e.g. eth0,eth1).
# Multi-interface example: SURICATA_IFACES=lan,opt1
# Single-interface example: SURICATA_IFACES=lan
SURICATA_IFACES=lan

# Legacy single-interface alias (deprecated — use SURICATA_IFACES above).
# Honoured as a fallback when SURICATA_IFACES is unset.
# SURICATA_IFACE=em0

# Zeek capture interface — physical trunk interface name (e.g. igb1, em0).
# deploy sets this in THREE places via the pfSense PHP API (GUI-visible):
#   1. installedpackages/zeek/config/0/active_interface in config.xml
#   2. /usr/local/etc/node.cfg  (zeekctl's capture interface source of truth)
#   3. zeek_iface const label in rendered/zeek/local.zeek (informational)
#
# Use the trunk (parent) interface, not a VLAN sub-interface:
#   igb1      ← correct: Zeek decodes 802.1Q natively, one sensor covers all VLANs
#   igb1.10   ← wrong: only sees VLAN 10; other VLANs invisible
#   lan       ← wrong: pfSense logical name resolves to igb1.10 (VLAN sub-iface)
ZEEK_IFACE=igb1

# Email address for zeekctl alert emails (log rotation warnings, host-up/down).
# Baked into rendered/zeek/zeekctl.cfg at render time.
# Defaults to root (local delivery only) when unset.
ZEEK_MAILTO=

# =============================================================================
# REST API Integration (post-deploy validation, error analysis, rule reloads)
# =============================================================================
# pfSense uses pfRest (https://pfrest.org/).
# OPNsense uses its native API (https://docs.opnsense.org/development/api.html).
#
# When credentials are unset, the SSH-only deploy path remains functional;
# only the post-deploy API validation and error-analysis features are skipped.
# -----------------------------------------------------------------------------

# Common
# TLS verification on router API. Leave "yes" in production. Disabling triggers
# a runtime WARN log line — only acceptable for lab/known self-signed certs.
API_TLS_VERIFY=yes
API_CONNECT_TIMEOUT=30
API_MAX_TIME=60

# -----------------------------------------------------------------------------
# AUTHENTICATION MODE
# -----------------------------------------------------------------------------
#   api_key  — long-lived static key. RECOMMENDED FOR AUTOMATION / CI.
#              Rotate quarterly. Both platforms supported.
#   jwt      — short-lived bearer token (pfSense only). BEST FOR INTERACTIVE
#              OPERATOR SESSIONS. The script logs in with username/password
#              and uses the returned JWT for the rest of the session.
#              Token is cached in-process only and never written to disk.
# -----------------------------------------------------------------------------
API_AUTH_MODE=api_key

# ---- pfSense / pfRest -------------------------------------------------------
# URL to the pfSense-pkg-RESTAPI .pkg matching your pfSense version.
# See https://pfrest.org/ for current releases. Used ONCE on first deploy by
# api_pfsense_install to install pfRest as the first package.
# Example:
#   PFSENSE_API_PKG_URL=https://github.com/pfrest/pfSense-pkg-RESTAPI/releases/download/v2.7.7/pfSense-2.8.1-pkg-RESTAPI.pkg
PFSENSE_API_PKG_URL=

# pfRest base URL (default: https://${ROUTER_HOST}/api/v2)
# PFSENSE_API_URL=https://192.168.1.1/api/v2

# --- pfSense: API_AUTH_MODE=api_key (recommended for automation) -----------
# Generated by: make api-bootstrap  (uses ROUTER_SSH_KEY above — no extra password needed)
# Rotate every 90 days: make api-bootstrap
PFSENSE_API_KEY=

# --- pfSense: API_AUTH_MODE=jwt (recommended for short-lived operator runs)-
# Used to obtain short-lived JWTs from /api/v2/auth/jwt.
# IMPORTANT: PFSENSE_API_PASSWORD is high-sensitivity — store the .env file
# encrypted with SOPS + age, or use a secret manager. Do NOT commit.
# PFSENSE_API_USERNAME=
# PFSENSE_API_PASSWORD=

# ---- OPNsense (native API) --------------------------------------------------
# OPNsense's native API only supports api_key mode (key+secret). JWT is
# NOT supported by OPNsense core — setting API_AUTH_MODE=jwt with
# ROUTER_PLATFORM=opnsense will fail loudly at api_init time.
#
# API base URL (default: https://${ROUTER_HOST}/api)
# OPNSENSE_API_URL=https://192.168.1.1/api

# Created in OPNsense UI: System -> Access -> Users -> [user] -> API keys.
# Downloaded as a key=value file; copy the two fields below.
OPNSENSE_API_KEY=
OPNSENSE_API_SECRET=

# ---- API integration toggles ------------------------------------------------
# Set true to skip pfRest install during deploy (e.g. if you manage it
# out-of-band or you're on a network without internet egress).
# SURU_SKIP_API_INSTALL=false

# Set true to skip post-deploy API health/validation calls entirely.
# SURU_SKIP_API_VALIDATE=false

# =============================================================================
# Encrypted pre-deploy backup
# =============================================================================
# Every deploy snapshots /conf/config.xml on the router BEFORE any change,
# encrypts it on the router via the platform's native crypt.inc helpers
# (AES-256-CBC + PBKDF2 sha256, 500_000 iterations — same code path the GUI's
# "Encrypt this configuration file" checkbox runs), and SCP-pulls the result
# into tier1-perimeter/backups/. On any deploy-step failure the driver
# auto-restores from this backup.
#
# REQUIRED unless SURU_SKIP_BACKUP=true. Set a strong passphrase. Store the
# .env via SOPS + age so this secret is never committed.
#
# The encrypted file is restorable from the router GUI:
#   pfSense:  Diagnostics > Backup & Restore > Restore Configuration
#             (check "Configuration file is encrypted", supply password)
#   OPNsense: System > Configuration > Backups > Restore (encrypted)
# -----------------------------------------------------------------------------
SURU_BACKUP_PASSWORD=

# Set true to disable the pre-deploy backup step entirely. Strongly discouraged
# — without this the deploy has no automatic rollback if a write_config fails
# midway. Only acceptable for first-deploy-on-throwaway-lab scenarios.
# SURU_SKIP_BACKUP=false

# -----------------------------------------------------------------------------
# pfBlockerNG IP Configuration — GeoIP (MaxMind) + ASN (IPinfo)
# -----------------------------------------------------------------------------
# When set, the deploy auto-enables pfBlockerNG's IP-config features (IP tab):
#   MAXMIND_ACCOUNT_ID + MAXMIND_LICENSE_KEY -> GeoIP country lookups + daily
#                          auto-update (pfBlockerNG `maxmind_account`,
#                          `maxmind_key`, `autogeoipupdate=on`). BOTH are
#                          required — GeoLite2 (GeoIP Update 3.1.1+) needs the
#                          account ID and the license key together.
#   IPINFO_TOKEN        -> ASN reporting, 24h cache (`asn_reporting=24hour`,
#                          `asn_token`)
# Each feature is enabled independently; leave its token(s) blank to keep it off.
# Free accounts:
#   MaxMind GeoLite2:  https://www.maxmind.com/en/geolite2/signup
#   IPinfo:            https://ipinfo.io/signup
# These are secrets — store the .env via SOPS + age; never commit real values.
# Note: the same MAXMIND_ACCOUNT_ID + MAXMIND_LICENSE_KEY are used by Tier 3
# (Logstash geoip) for the GeoLite2 download — keep them identical across tiers.
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
IPINFO_TOKEN=
