# =============================================================================
# SURU Platform — tier4-operations/.env.example
# =============================================================================
# Copy to .env and fill in the values. Never commit .env.
#
# This file holds variables consumed by the Tier 4 stacks (monitoring +
# frontdoor). Cross-tier values (e.g. OPENSEARCH_INITIAL_ADMIN_PASSWORD used
# by Grafana's OpenSearch datasource) must match the value in tier3-core/.env.
# =============================================================================

# ── Frontdoor (Tier 4 reverse proxy / sole LAN entry point) ───────────────────
# The frontdoor proxy is the only container that binds host ports on the LAN
# side. Every other internal service is reachable only through it.
#
# FRONTDOOR_FQDN     Primary hostname clients use to reach the LAN entry
#                    point. Default `suru.local`. Resolved via:
#                      (a) mDNS — advertised by the bundled
#                          `suru.t4.frontdoor.mdns` sidecar (avahi-daemon
#                          in host network mode). Works on macOS / Linux
#                          out of the box; Windows needs Apple Bonjour.
#                      (b) Router DNS — `bash scripts/deploy.sh register-dns`
#                          pushes a static host override to pfSense/OPNsense
#                          Unbound so every LAN client resolves it.
# FRONTDOOR_MDNS_ALIASES
#                    Comma-separated list of additional names the mDNS
#                    sidecar advertises (all pointing at FRONTDOOR_IP).
#                    Default `suru.local,soc.local` — `soc.local` is kept
#                    for backward compatibility with the previous default.
#                    Every entry is also added to the frontdoor TLS cert's
#                    Subject Alternative Name list, so all advertised names
#                    are trusted.
# FRONTDOOR_PORT     Host port nginx listens on for HTTPS. Default 443.
# FRONTDOOR_IP       LAN-routable IPv4 of the Docker host running the
#                    frontdoor. Used (1) as a SAN entry in the frontdoor TLS
#                    cert so https://<IP>/ validates, (2) as the target the
#                    mDNS sidecar advertises for each alias, and (3) as the
#                    target when registering FRONTDOOR_FQDN on the router's
#                    DNS resolver. Default 127.0.0.1 is fine for local dev,
#                    but the mDNS sidecar REFUSES to advertise loopback —
#                    set this to the real LAN IP before bringing the stack
#                    up on a SOHO host.
# FRONTDOOR_BASIC_AUTH_USER / ..._PASSWORD
#                    Single shared user. htpasswd is materialised inside the
#                    container at start; never written to disk.
FRONTDOOR_FQDN=suru.local
# Comma-separated ingestion FQDNs. Each is registered as a DNS host override
# (pointing to FRONTDOOR_IP) and routed via nginx SNI passthrough to the
# appropriate backend on port 443. Add new collectors here; the entrypoint
# generates the nginx SNI map automatically at startup.
# Example: syslog.suru.local,beats.suru.local,vector.suru.local,otel.suru.local
FRONTDOOR_INGESTION_FQDNS=syslog.suru.local
FRONTDOOR_MDNS_ALIASES=suru.local,soc.local
FRONTDOOR_PORT=443
FRONTDOOR_IP=127.0.0.1
FRONTDOOR_BASIC_AUTH_USER=admin
FRONTDOOR_BASIC_AUTH_PASSWORD=CHANGE_ME_FrontdoorStrongPass!

# ── Docker platform (monitoring + frontdoor) ──────────────────────────────────
# Target CPU architecture for Docker images. Set to linux/arm64 on Apple Silicon
# (macOS M-series). Leave linux/amd64 for x86_64 Linux SIEM hosts. All image
# digests in compose.yaml are manifest-list digests (platform-neutral), so the
# correct arch layer is pulled automatically based on this value.
DOCKER_PLATFORM=linux/amd64

# ── InfluxDB (monitoring) ─────────────────────────────────────────────────────
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=CHANGE_ME_StrongPass_influx!
INFLUXDB_ORG=suru
INFLUXDB_BUCKET=siem-metrics
INFLUXDB_TOKEN=CHANGE_ME_influx_token_32chars

# ── Grafana (monitoring) ──────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_StrongPass_grafana!

# ── Cross-tier values (must match tier3-core/.env) ────────────────────────────
# Grafana's OpenSearch datasource authenticates as `admin` against the
# tier-3 OpenSearch cluster. Keep this value identical to the one in
# tier3-core/.env or the datasource will fail to load.
OPENSEARCH_INITIAL_ADMIN_PASSWORD=CHANGE_ME_StrongPass1!

# ── DNS auto-registration target (consumed by scripts/register-dns.sh) ────────
# The frontdoor's tier4 deploy script can register FRONTDOOR_FQDN on the
# perimeter router's DNS resolver so all LAN clients (including Windows)
# resolve it without mDNS. Credentials live in tier1-perimeter/.env
# (ROUTER_HOST, ROUTER_PLATFORM, PFSENSE_API_*).
#
# REGISTER_DNS_ON_DEPLOY  When true/yes/1, `deploy.sh deploy` and
#                         `deploy.sh restart` auto-register DNS whenever the
#                         frontdoor group is in scope (full or --group
#                         frontdoor/proxy). `deploy.sh start` does NOT
#                         auto-register — use `deploy` or `register-dns`.
#
# REGISTER_DNS_STRICT     When true/yes/1, a DNS registration failure causes
#                         the deploy to exit non-zero. Default: false (WARN
#                         only — frontdoor stays up even if DNS failed).
REGISTER_DNS_ON_DEPLOY=false
REGISTER_DNS_STRICT=false

# ── Frontdoor content (git-sync sidecar) ──────────────────────────────────────
# The frontdoor's `/` route is served by nginx from a shared Docker volume
# that the suru.t4.frontdoor.content sidecar populates by periodically
# cloning the cybrd0ne/suru-frontdoor-content repository.
#
# CONTENT_REPO_URL     HTTPS clone URL. Default points at the canonical repo.
# CONTENT_REPO_REF     Branch / tag / sha to track. Default: main.
# CONTENT_REPO_TOKEN   GitHub fine-grained PAT scoped to suru-frontdoor-content
#                      with Contents: read-only. Required. The token is fed to
#                      git via GIT_ASKPASS inside the container — it is never
#                      persisted to git config on disk and never echoed in logs.
# CONTENT_SYNC_PERIOD  Poll interval. Accepts "60s", "5m", "1h". Default 60s.
CONTENT_REPO_URL=https://github.com/cybrd0ne/suru-frontdoor-content.git
CONTENT_REPO_REF=main
CONTENT_REPO_TOKEN=CHANGE_ME_github_pat_with_contents_read_on_suru_frontdoor_content
CONTENT_SYNC_PERIOD=60s
