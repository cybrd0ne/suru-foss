# ── Docker platform ───────────────────────────────────────────────────────────
# Target CPU architecture for Docker images. Set to linux/arm64 on Apple Silicon
# (macOS M-series). Leave linux/amd64 for x86_64 Linux SIEM hosts. All image
# digests are manifest-list digests (platform-neutral).
DOCKER_PLATFORM=linux/amd64

# ── OpenSearch / Datalake ──────────────────────────────────────────────────────
OPENSEARCH_INITIAL_ADMIN_PASSWORD=CHANGE_ME_StrongPass1!
OPENSEARCH_JAVA_OPTS=-Xms2g -Xmx2g

# ── OpenSearch Dashboards ──────────────────────────────────────────────────────
OPENSEARCH_DASHBOARDS_USER=kibanaserver
OPENSEARCH_DASHBOARDS_PASSWORD=CHANGE_ME_StrongPass2!

# ── SURU Security Analyst user ────────────────────────────────────────────────
MYSECURITY_OPENSEARCH_PASSWORD=CHANGE_ME_StrongPass_analyst!

# ── Router platform — controls which Logstash profile deploy.sh starts ─────────
# pfsense  → logstash-pfsense  (mTLS syslog-ng TCP input + pfSense pipelines)
# opnsense → logstash-opnsense (syslog UDP input + OPNsense pipelines)
# unset    → all profiles start (multi-platform or explicit --logstash-profile)
ROUTER_PLATFORM=pfsense

# ── Logstash ───────────────────────────────────────────────────────────────────
LOGSTASH_OPENSEARCH_USER=logstash
LOGSTASH_OPENSEARCH_PASSWORD=CHANGE_ME_StrongPass1!
LOGSTASH_JAVA_OPTS=-Xms512m -Xmx512m

# ── GeoIP enrichment (MaxMind GeoLite2) ────────────────────────────────────────
# When BOTH are set, the geoipupdate init container downloads GeoLite2-City +
# GeoLite2-ASN and the Logstash geoip pipeline (35-geoip.conf) enriches
# firewall/Suricata/Zeek events with source/destination .geo.* + .as.* fields.
# Leave blank to disable — the geoip pipeline then runs in passthrough mode and
# ingestion is unaffected. Free GeoLite2 account: https://www.maxmind.com/en/geolite2/signup
# (Account ID + License Key under "Manage License Keys"). The license key is the
# same value as Tier 1's MAXMIND_LICENSE_KEY (pfBlockerNG GeoIP). Secrets — store
# the .env via SOPS + age; never commit real values.
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
# Editions to download (space-separated). Default covers City (geo) + ASN.
MAXMIND_EDITION_IDS=GeoLite2-City GeoLite2-ASN

# ── Monitoring / Frontdoor (Tier 4) ───────────────────────────────────────────
# Variables for the monitoring stack (INFLUXDB_*, GRAFANA_*) and the frontdoor
# proxy (FRONTDOOR_FQDN, FRONTDOOR_PORT, FRONTDOOR_IP,
# FRONTDOOR_BASIC_AUTH_USER / ..._PASSWORD) live in tier4-operations/.env.
# See tier4-operations/.env.example for the template.

# ── Dashboards Access ─────────────────────────────────────────────────────────
# Internal URL — used by containers for container-to-container API calls.
# Uses Docker-internal DNS (hostname of the dashboards container).
# Do NOT change unless you rename the dashboards service hostname.
DASHBOARDS_INTERNAL_URL=https://suru-t3-datalake-dashboards:5601

# External URL — user-facing access from browsers and external tools.
# All external access goes through the Tier 4 frontdoor proxy; the dashboards
# landing page is the `/` route, so this URL is just the frontdoor base URL
# with no path. The mDNS name is advertised by the bundled
# suru.t4.frontdoor.mdns sidecar (avahi-daemon, network_mode: host), so
# macOS / Linux clients resolve it without any host-side configuration.
# Windows clients need either Apple Bonjour OR a router-side DNS host
# override (run `bash tier4-operations/scripts/deploy.sh register-dns`).
DASHBOARDS_EXTERNAL_URL=https://suru.local/

# (Frontdoor variables — FRONTDOOR_FQDN, FRONTDOOR_MDNS_ALIASES,
#  FRONTDOOR_PORT, FRONTDOOR_IP, FRONTDOOR_BASIC_AUTH_USER / ..._PASSWORD
#  — live in tier4-operations/.env. See tier4-operations/.env.example.)
