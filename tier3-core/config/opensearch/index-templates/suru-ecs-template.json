# ECS v8 index template for all suru-* indices
# Applied automatically via OpenSearch API on first ingest
# PUT _index_template/suru-ecs-template

PUT /_index_template/suru-ecs-template
{
  "index_patterns": ["suru-*"],
  "priority": 100,
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "index.refresh_interval": "10s",
      "index.codec": "best_compression",
      "index.mapping.ignore_malformed": true,
      "index.mapping.total_fields.limit": 2000
    },
    "mappings": {
      "dynamic_templates": [
        {
          "strings_as_keyword": {
            "match_mapping_type": "string",
            "mapping": { "type": "keyword", "ignore_above": 1024 }
          }
        },
        {
          "message_as_text": {
            "match": "message",
            "mapping": { "type": "text", "norms": false }
          }
        }
      ],
      "properties": {
        "@timestamp": { "type": "date" },
        "tags":       { "type": "keyword" },
        "in_iface":   { "type": "keyword", "ignore_above": 1024 },

        "ecs": {
          "properties": {
            "version": { "type": "keyword" }
          }
        },

        "event": {
          "properties": {
            "action":   { "type": "keyword" },
            "category": { "type": "keyword" },
            "created":  { "type": "date" },
            "dataset":  { "type": "keyword" },
            "duration": { "type": "long" },
            "ingested": { "type": "date" },
            "kind":     { "type": "keyword" },
            "module":   { "type": "keyword" },
            "original": { "type": "text", "norms": false },
            "outcome":  { "type": "keyword" },
            "severity": { "type": "long" },
            "type":     { "type": "keyword" }
          }
        },

        "source": {
          "properties": {
            "ip":    { "type": "ip" },
            "port":  { "type": "integer" },
            "bytes": { "type": "long" },
            "mac":   { "type": "keyword" },
            "geo": {
              "properties": {
                "country_name":     { "type": "keyword" },
                "country_iso_code": { "type": "keyword" },
                "city_name":        { "type": "keyword" },
                "region_name":      { "type": "keyword" },
                "region_iso_code":  { "type": "keyword" },
                "continent_name":   { "type": "keyword" },
                "location":         { "type": "geo_point" }
              }
            },
            "as": {
              "properties": {
                "number": { "type": "long" },
                "organization": {
                  "properties": {
                    "name": { "type": "keyword" }
                  }
                }
              }
            }
          }
        },

        "destination": {
          "properties": {
            "ip":    { "type": "ip" },
            "port":  { "type": "integer" },
            "bytes": { "type": "long" },
            "geo": {
              "properties": {
                "country_name":     { "type": "keyword" },
                "country_iso_code": { "type": "keyword" },
                "city_name":        { "type": "keyword" },
                "region_name":      { "type": "keyword" },
                "region_iso_code":  { "type": "keyword" },
                "continent_name":   { "type": "keyword" },
                "location":         { "type": "geo_point" }
              }
            },
            "as": {
              "properties": {
                "number": { "type": "long" },
                "organization": {
                  "properties": {
                    "name": { "type": "keyword" }
                  }
                }
              }
            }
          }
        },

        "network": {
          "properties": {
            "transport":   { "type": "keyword" },
            "direction":   { "type": "keyword" },
            "protocol":    { "type": "keyword" },
            "application": { "type": "keyword" },
            "type":        { "type": "keyword" }
          }
        },

        "observer": {
          "properties": {
            "hostname": { "type": "keyword" },
            "type":     { "type": "keyword" },
            "vendor":   { "type": "keyword" },
            "product":  { "type": "keyword" },
            "ingress": {
              "properties": {
                "interface": {
                  "properties": {
                    "name": { "type": "keyword" }
                  }
                }
              }
            }
          }
        },

        "rule": {
          "properties": {
            "name":     { "type": "keyword" },
            "category": { "type": "keyword" },
            "id":       { "type": "keyword" },
            "ruleset":  { "type": "keyword" },
            "index":    { "type": "keyword" }
          }
        },

        "dns": {
          "properties": {
            "rrname":        { "type": "keyword" },
            "rrtype":        { "type": "keyword" },
            "response_code": { "type": "keyword" },
            "resolved":      { "type": "keyword" },
            "question": {
              "properties": {
                "name":  { "type": "keyword" },
                "type":  { "type": "keyword" },
                "class": { "type": "keyword" }
              }
            }
          }
        },

        "dhcp": {
          "properties": {
            "host_name":      { "type": "keyword" },
            "assigned_addr":  { "type": "keyword" },
            "requested_addr": { "type": "keyword" },
            "message_types":  { "type": "keyword" },
            "domain":         { "type": "keyword" },
            "lease_time":     { "type": "float" }
          }
        },

        "http": {
          "properties": {
            "hostname":    { "type": "keyword" },
            "url":         { "type": "keyword" },
            "http_method": { "type": "keyword" },
            "status":      { "type": "long" }
          }
        },

        "tls": {
          "properties": {
            "sni":     { "type": "keyword" },
            "version": { "type": "keyword" }
          }
        },

        "threat": {
          "properties": {
            "indicator": {
              "properties": {
                "name":       { "type": "keyword" },
                "type":       { "type": "keyword" },
                "confidence": { "type": "keyword" }
              }
            },
            "feed": {
              "properties": {
                "name": { "type": "keyword" }
              }
            }
          }
        },

        "zeek": {
          "properties": {
            "uid":         { "type": "keyword" },
            "file_source": { "type": "keyword" }
          }
        },

        "_suru": {
          "properties": {
            "log_type": { "type": "keyword" },
            "tier":     { "type": "keyword" }
          }
        },

        "service": {
          "properties": {
            "type": { "type": "keyword" }
          }
        },

        "process": {
          "properties": {
            "pid": { "type": "integer" }
          }
        },

        "host": {
          "properties": {
            "name":     { "type": "keyword" },
            "hostname": { "type": "keyword" }
          }
        }
      }
    }
  }
}
